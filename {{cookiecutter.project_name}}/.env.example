# REROUTE Configuration for {{ cookiecutter.project_name }}
# Generated by REROUTE
#
# After setting up this file, install dependencies:
#   uv sync

# Application Settings (REROUTE defaults shown for reference)
# Host: 0.0.0.0
# Port: 7376
REROUTE_DEBUG=False
REROUTE_HOST=0.0.0.0
REROUTE_PORT=7376

# Database Configuration
REROUTE_DATABASE_URL=
{% if cookiecutter.database_type == 'postgresql' %}# Format: postgresql://user:password@localhost:5432/{{ cookiecutter.project_name }}
{% elif cookiecutter.database_type == 'mysql' %}# Format: mysql+pymysql://user:password@localhost:3306/{{ cookiecutter.project_name }}
{% elif cookiecutter.database_type == 'mongodb' %}# Format: mongodb://localhost:27017/{{ cookiecutter.project_name }}
{% elif cookiecutter.database_type == 'sqlite' %}# Format: sqlite:///./{{ cookiecutter.project_name }}.db
{% endif %}

# SECURITY: Never commit real credentials to version control
# Use environment variables for production

# JWT Configuration (REROUTE defaults shown for reference)
# Algorithm: HS256
# Access token expiry: 30 minutes
# Refresh token expiry: 7 days

# REQUIRED: Generate secure secret
# python -c "import secrets; print(secrets.token_urlsafe(32))"
REROUTE_JWT_SECRET=CHANGE_THIS_SECRET

# CORS Settings
# SECURITY: Default origins are restrictive. Add your domains for production.
REROUTE_ENABLE_CORS=True
REROUTE_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
# For production:
#   REROUTE_CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
